{
  "manifest_version": 3,
  "name": "YouTube Watch Later Recommender",
  "version": "1.1.0",
  "description": "Inject Watch Later videos into YouTube homepage",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
